# ─── JEKYLL BUILD OUTPUT ───────────────────────────
# The compiled site.
# Never commit this — GitHub rebuilds it from source on every push.
_site/

# Jekyll's caching folders for faster rebuilds.
# These should be local only.
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# ─── RUBY / BUNDLER ────────────────────────────────
# Gems installed locally by `bundle install`.
# The /vendor prefix anchors this to the repo root only.
/vendor

# Gemfile.lock intentionally excluded for GitHub Pages.
# GitHub always uses its own gem versions server-side, so committing a lock file causes version conflicts.
# See: https://github.com/github/pages-gem/issues/768
Gemfile.lock

# ─── VS CODE ───────────────────────────────────────
.vscode/

# ─── OS FILES ──────────────────────────────────────
.DS_Store        # macOS folder metadata (invisible, but annoying in diffs)
Thumbs.db        # Windows thumbnail cache
