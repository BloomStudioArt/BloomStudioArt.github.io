# Gemfile

# Where to download gems from (like PyPI for Python)
source "https://rubygems.org"

# The github-pages gem is a meta-package that bundles the exact version of Jekyll and every plugin that GitHub's servers use.
# This is what ensures "it works locally" = "it works in production."
gem "github-pages", group: :jekyll_plugins

# The `bundle exec` command in the terminal tells Ruby to use the gem versions in this Gemfile.